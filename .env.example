# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Get from https://dashboard.stripe.com/webhooks
# Register endpoint: https://yiafirm.com/webhook
# Event to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PDF ───────────────────────────────────────────────────────────────────────
# Absolute path to the PDF on the server (outside the public/static directory)
PDF_FILE_PATH=/home/youruser/protected/Yia-AI-Turnkey-Toolkit.pdf

# ── Server ────────────────────────────────────────────────────────────────────
# Production domain — no trailing slash
DOMAIN=https://yiafirm.com
